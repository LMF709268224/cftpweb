{
  "server": "candbff",
  "base_path": "",
  "auth_type": "Bearer JWT",
  "auth_header": "Authorization: Bearer <token>",
  "response_envelope": {
    "description": "所有接口统一使用以下 JSON 响应结构",
    "fields": {
      "code": { "type": "int", "description": "HTTP 状态码" },
      "message": { "type": "string", "description": "状态描述" },
      "data": { "type": "object", "description": "业务数据，具体结构见各接口 response.data 定义" }
    }
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/health",
      "description": "健康检查",
      "auth_required": false,
      "request": {
        "params": [],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "status": { "type": "string", "description": "服务状态", "example": "ok" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/auth/login-url",
      "description": "获取 Casdoor 登录页 URL，前端拿到后 redirect 用户到 Casdoor",
      "auth_required": false,
      "request": {
        "params": [],
        "query": [
          { "name": "redirect_uri", "type": "string", "required": true, "description": "Casdoor 登录成功后的回调地址" }
        ],
        "body": null
      },
      "response": {
        "data": {
          "url": { "type": "string", "description": "Casdoor 登录页完整 URL" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/auth/register-url",
      "description": "获取 Casdoor 注册页 URL",
      "auth_required": false,
      "request": {
        "params": [],
        "query": [
          { "name": "redirect_uri", "type": "string", "required": true, "description": "Casdoor 注册成功后的回调地址" }
        ],
        "body": null
      },
      "response": {
        "data": {
          "url": { "type": "string", "description": "Casdoor 注册页完整 URL" }
        }
      }
    },
    {
      "method": "POST",
      "path": "/auth/login",
      "description": "Casdoor OAuth 回调: code 换 JWT",
      "auth_required": false,
      "request": {
        "params": [],
        "query": [],
        "body": {
          "code": { "type": "string", "required": true, "description": "Casdoor 回调的 authorization code" },
          "state": { "type": "string", "required": true, "description": "Casdoor 回调的 state" }
        }
      },
      "response": {
        "data": {
          "access_token": { "type": "string", "description": "JWT access token" },
          "refresh_token": { "type": "string", "description": "用于刷新 access_token" },
          "expires_at": { "type": "string", "description": "过期时间 RFC3339" },
          "user": {
            "id": { "type": "string", "description": "用户ID" },
            "name": { "type": "string", "description": "用户名" },
            "email": { "type": "string", "description": "邮箱" }
          }
        }
      }
    },
    {
      "method": "POST",
      "path": "/auth/refresh",
      "description": "用 refresh_token 换取新的 access_token",
      "auth_required": false,
      "request": {
        "params": [],
        "query": [],
        "body": {
          "refresh_token": { "type": "string", "required": true, "description": "login 接口返回的 refresh_token" }
        }
      },
      "response": {
        "data": {
          "access_token": { "type": "string", "description": "新的 JWT access token" },
          "refresh_token": { "type": "string", "description": "新的 refresh_token" },
          "expires_at": { "type": "string", "description": "过期时间 RFC3339" },
          "user": {
            "id": { "type": "string", "description": "用户ID" },
            "name": { "type": "string", "description": "用户名" },
            "email": { "type": "string", "description": "邮箱" }
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/courses",
      "description": "获取课程列表",
      "auth_required": true,
      "request": {
        "params": [],
        "query": [
          { "name": "level", "type": "string", "required": false, "description": "科目等级筛选" },
          { "name": "paper", "type": "string", "required": false, "description": "试卷/考点筛选" }
        ],
        "body": null
      },
      "response": {
        "data": {
          "type": "array",
          "description": "课程列表（由 glms 微服务直接返回）",
          "items": {
            "courseId": { "type": "string", "description": "课程ID" },
            "businessUnit": { "type": "string", "description": "所属业务系统" },
            "name": { "type": "string", "description": "课程名称" },
            "description": { "type": "string", "description": "课程描述" },
            "level": { "type": "string", "description": "Level层级" },
            "paper": { "type": "string", "description": "Paper名称" },
            "createdAt": { "type": "string", "description": "创建时间 RFC3339" },
            "updatedAt": { "type": "string", "description": "更新时间 RFC3339" }
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/courses/{courseId}",
      "description": "获取单个课程详情",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "courseId", "type": "string", "required": true, "description": "课程ID" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "courseId": { "type": "string", "description": "课程ID" },
          "businessUnit": { "type": "string", "description": "所属业务系统" },
          "name": { "type": "string", "description": "课程名称" },
          "description": { "type": "string", "description": "课程描述" },
          "level": { "type": "string", "description": "Level层级" },
          "paper": { "type": "string", "description": "Paper名称" },
          "createdAt": { "type": "string", "description": "创建时间 RFC3339" },
          "updatedAt": { "type": "string", "description": "更新时间 RFC3339" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/courses/{courseId}/packages",
      "description": "获取课程的资料包列表",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "courseId", "type": "string", "required": true, "description": "课程ID" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "type": "array",
          "description": "资料包列表（由 glms 微服务直接返回）",
          "items": {
            "coursePackageId": { "type": "string", "description": "资料包ID" },
            "businessUnit": { "type": "string", "description": "所属业务系统" },
            "name": { "type": "string", "description": "资料包名称" },
            "description": { "type": "string", "description": "资料包描述" },
            "type": { "type": "string", "description": "资料包类型" },
            "bucketName": { "type": "string", "description": "OSS Bucket名称" },
            "bucketType": { "type": "int", "description": "对象存储服务商类型: 1=AWS_S3, 2=ALIBABA_OSS" },
            "createdAt": { "type": "string", "description": "创建时间 RFC3339" },
            "updatedAt": { "type": "string", "description": "更新时间 RFC3339" }
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/packages/{packageId}/materials",
      "description": "获取资料包的资料列表",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "packageId", "type": "string", "required": true, "description": "资料包ID" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "type": "array",
          "description": "资料列表（由 glms 微服务直接返回）",
          "items": {
            "materialId": { "type": "string", "description": "资料ID" },
            "coursePackageId": { "type": "string", "description": "所属资料包ID" },
            "title": { "type": "string", "description": "资料标题" },
            "materialType": { "type": "int", "description": "资料类型: 1=PDF, 2=DOCUMENT, 3=VIDEO, 4=AUDIO" },
            "fileKey": { "type": "string", "description": "OSS对象Key" },
            "fileSize": { "type": "int", "description": "文件大小（字节）" },
            "durationSeconds": { "type": "int", "description": "时长（秒），视频/音频类型使用" },
            "createdAt": { "type": "string", "description": "创建时间 RFC3339" },
            "updatedAt": { "type": "string", "description": "更新时间 RFC3339" }
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/materials/{materialId}/url",
      "description": "获取资料的签名访问URL",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "materialId", "type": "string", "required": true, "description": "资料ID" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "url": { "type": "string", "description": "带签名的访问URL" },
          "expiresAt": { "type": "string", "description": "URL过期时间 RFC3339" }
        }
      }
    },
    {
      "method": "POST",
      "path": "/api/progress",
      "description": "批量上报学习进度",
      "auth_required": true,
      "request": {
        "params": [],
        "query": [],
        "body": {
          "records": {
            "type": "array",
            "required": true,
            "description": "进度记录列表，至少一条",
            "items": {
              "materialId": { "type": "string", "required": true, "description": "资料ID" },
              "coursePackageId": { "type": "string", "required": true, "description": "资料包ID" },
              "progressType": { "type": "int", "required": true, "description": "进度类型: 1=视频秒数, 2=文档百分比" },
              "progressValue": { "type": "float", "required": true, "description": "进度值：视频为秒数，文档为百分比(0-100)" },
              "recordedAt": { "type": "string", "required": true, "description": "记录时间 RFC3339", "example": "2025-01-15T10:30:00Z" }
            }
          }
        }
      },
      "response": {
        "data": {
          "acceptedCount": { "type": "int", "description": "成功接收条数" },
          "rejectedCount": { "type": "int", "description": "拒绝条数" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/progress",
      "description": "查询学习进度",
      "auth_required": true,
      "request": {
        "params": [],
        "query": [
          { "name": "materialId", "type": "string", "required": false, "description": "资料ID，为空则查询该考生所有进度" },
          { "name": "packageId", "type": "string", "required": false, "description": "资料包ID，为空则不过滤" }
        ],
        "body": null
      },
      "response": {
        "data": {
          "type": "array",
          "description": "进度记录列表（由 glms 微服务直接返回）",
          "items": {
            "candidateId": { "type": "string", "description": "考生ID" },
            "materialId": { "type": "string", "description": "资料ID" },
            "coursePackageId": { "type": "string", "description": "资料包ID" },
            "progressType": { "type": "int", "description": "进度类型" },
            "progressValue": { "type": "float", "description": "进度值" },
            "recordedAt": { "type": "string", "description": "记录时间 RFC3339" }
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/exams/{examId}",
      "description": "获取考试信息",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "examId", "type": "string", "required": true, "description": "考试ID" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "examId": { "type": "string", "description": "考试ID" },
          "programCode": { "type": "string", "description": "项目代码" },
          "examCode": { "type": "string", "description": "科目代码" },
          "examStatus": { "type": "string", "description": "流程状态" },
          "resultStatus": { "type": "string", "description": "成绩状态" },
          "totalScore": { "type": "float", "description": "总分" },
          "isPassed": { "type": "bool", "description": "是否通过" },
          "candidateFirstName": { "type": "string", "description": "考生名字" },
          "candidateLastName": { "type": "string", "description": "考生姓氏" },
          "candidateEmail": { "type": "string", "description": "考生邮箱" },
          "confirmationNumber": { "type": "string", "description": "预约确认号" },
          "appointmentStartTime": { "type": "string", "description": "预约开始时间" },
          "appointmentEndTime": { "type": "string", "description": "预约结束时间" },
          "siteName": { "type": "string", "description": "考点名称" },
          "lastTermurlTimestamp": { "type": "string", "description": "最后一次TermURL回调时间" },
          "lastTermurlType": { "type": "string", "description": "最后一次TermURL回调类型" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/exams/{examId}/result",
      "description": "获取考试成绩详情（含分数明细）",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "examId", "type": "string", "required": true, "description": "考试ID" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "examId": { "type": "string", "description": "考试ID" },
          "totalScore": { "type": "float", "description": "总分" },
          "isPassed": { "type": "bool", "description": "是否通过" },
          "scoreDetails": { "type": "object", "description": "分数明细（JSON对象，由 gexam 返回的 score_details_json 解析）" },
          "scoreDetailsRaw": { "type": "string", "description": "分数明细原始JSON字符串（仅当解析失败时出现）" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/exams/{examId}/schedule-url",
      "description": "获取考试预约/改期/取消的跳转URL",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "examId", "type": "string", "required": true, "description": "考试ID" }
        ],
        "query": [
          { "name": "type", "type": "string", "required": true, "description": "操作类型: schd=ԤԼ, reschd=改期, cancel=取消" },
          { "name": "termUrlBase", "type": "string", "required": true, "description": "GEE完成后的回调基础URL（由前端传入）" }
        ],
        "body": null
      },
      "response": {
        "data": {
          "url": { "type": "string", "description": "ԤԼ/改期/取消的跳转URL" }
        }
      }
    },
    {
      "method": "POST",
      "path": "/api/exams/{examId}/termurl",
      "description": "GEE TermURL 回调 — 当GEE(ProScheduler)完成后，考生浏览器重定向到的term_url触发前端回调此接口",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "examId", "type": "string", "required": true, "description": "考试ID" }
        ],
        "query": [],
        "body": {
          "urlType": { "type": "string", "required": true, "description": "操作类型: schd=ԤԼ, reschd=改期, cancel=取消" },
          "callbackBody": { "type": "string", "required": false, "description": "GEE回传的完整JSON字符串（可能为空）" }
        }
      },
      "response": {
        "data": {
          "examId": { "type": "string", "description": "考试ID" },
          "examStatus": { "type": "string", "description": "考试状态" }
        }
      }
    },
    {
      "method": "POST",
      "path": "/api/payments",
      "description": "创建支付请求",
      "auth_required": true,
      "request": {
        "params": [],
        "query": [],
        "body": {
          "orderId": { "type": "string", "required": true, "description": "业务订单号（唯一）" },
          "lineItems": {
            "type": "array",
            "required": true,
            "description": "商品列表，至少一条",
            "items": {
              "name": { "type": "string", "required": true, "description": "产品名称" },
              "description": { "type": "string", "required": true, "description": "产品描述" },
              "unitAmount": { "type": "int", "required": true, "description": "单价（分）" },
              "quantity": { "type": "int", "required": true, "description": "数量" },
              "currency": { "type": "string", "required": true, "description": "货币代码，如 \"usd\"" }
            }
          },
          "metadata": { "type": "object", "required": false, "description": "扩展元数据（key-value map）" },
          "successUrl": { "type": "string", "required": true, "description": "支付成功后的跳转URL" },
          "cancelUrl": { "type": "string", "required": true, "description": "用户取消支付后的跳转URL" }
        }
      },
      "response": {
        "data": {
          "orderId": { "type": "string", "description": "业务订单号" },
          "status": { "type": "string", "description": "支付内部状态" },
          "stripeCheckoutUrl": { "type": "string", "description": "Stripe Checkout 跳转URL，前端拿到后重定向用户到该地址" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/payments/{orderId}",
      "description": "查询支付状态",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "orderId", "type": "string", "required": true, "description": "业务订单号" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "orderId": { "type": "string", "description": "业务订单号" },
          "requestStatus": { "type": "string", "description": "gpay内部状态: pending_create, pending_payment, completed, cancelled, failed" },
          "sessionStatus": { "type": "string", "description": "Stripe Session״̬: open, complete, expired" },
          "paymentStatus": { "type": "string", "description": "Stripe支付状态: unpaid, paid" },
          "totalAmount": { "type": "int", "description": "总金额（分）" },
          "currency": { "type": "string", "description": "货币代码" },
          "stripeCheckoutUrl": { "type": "string", "description": "Stripe Checkout URL（可选）" }
        }
      }
    },
    {
      "method": "DELETE",
      "path": "/api/payments/{orderId}",
      "description": "取消支付",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "orderId", "type": "string", "required": true, "description": "业务订单号" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "success": { "type": "bool", "description": "是否取消成功" },
          "message": { "type": "string", "description": "结果消息" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/invoices/{orderId}",
      "description": "查询发票状态",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "orderId", "type": "string", "required": true, "description": "业务订单号" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "invoiceId": { "type": "string", "description": "Xero发票ID" },
          "paymentId": { "type": "string", "description": "Xero支付ID" },
          "requestStatus": { "type": "string", "description": "业务状态: pending_invoice, pending_payment, completed, failed" },
          "subTotal": { "type": "float", "description": "不含税总额" },
          "totalTax": { "type": "float", "description": "总税额" },
          "total": { "type": "float", "description": "含税总额" },
          "errorMsg": { "type": "string", "description": "错误信息（如有）" }
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/invoices/{orderId}/pdf",
      "description": "下载发票PDF文件",
      "auth_required": true,
      "request": {
        "params": [
          { "name": "orderId", "type": "string", "required": true, "description": "业务订单号" }
        ],
        "query": [],
        "body": null
      },
      "response": {
        "content_type": "application/pdf",
        "description": "直接返回PDF二进制流，非JSON格式。Content-Disposition包含文件名"
      }
    },
    {
      "method": "GET",
      "path": "/api/dashboard",
      "description": "首页仪表盘，拼接用户信息、待办事项、学习进度",
      "auth_required": true,
      "request": {
        "params": [],
        "query": [],
        "body": null
      },
      "response": {
        "data": {
          "user": {
            "name": { "type": "string", "description": "用户姓名" },
            "membershipLevel": { "type": "string", "description": "会员等级" }
          },
          "pendingItems": {
            "type": "array",
            "description": "待处理事项列表",
            "items": {
              "type": { "type": "string", "description": "事项类型: message / record_review / exam_exemption" },
              "count": { "type": "int", "description": "数量" },
              "description": { "type": "string", "description": "描述" }
            }
          },
          "currentLearning": {
            "courseId": { "type": "string", "description": "课程ID" },
            "name": { "type": "string", "description": "课程名称" },
            "description": { "type": "string", "description": "课程描述" },
            "totalProgress": { "type": "int", "description": "总进度百分比" },
            "completedModules": { "type": "int", "description": "已完成模块数" },
            "totalModules": { "type": "int", "description": "总模块数" },
            "currentModule": { "type": "string", "description": "当前学习模块" }
          },
          "stats": {
            "coursesInProgress": { "type": "int", "description": "进行中的课程数" },
            "certificationsEarned": { "type": "int", "description": "已获得认证数" },
            "membershipLevel": { "type": "string", "description": "会员等级" },
            "unreadMessages": { "type": "int", "description": "未读消息数" }
          }
        }
      }
    },
